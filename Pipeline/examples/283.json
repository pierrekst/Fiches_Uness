          "rows": [
            [
              {"html": "<strong>Constipation de transit</strong>"},
              {"html": "↓ fréquence/amplitude des contractions coliques → stase prolongée → selles déshydratées"},
              {"html": "↓ nombre de selles/sem, selles petites et dures"}
            ],
            [
              {"html": "<strong>Dyschésie (distale)</strong>"},
              {"html": "Défaut de relaxation / contraction paradoxale du sphincter anal externe <em>et/ou</em> troubles de la statique pelvienne (rectocèle, périnée descendant, procidence interne)"},
              {"html": "Efforts de poussée, évacuation incomplète, manœuvres digitales"}
            ],
            [
              {"html": "<strong>Mixte</strong>"},
              {"html": "Association des deux mécanismes (fréquente)"},
              {"html": "Tableau combiné"}
            ]
          ]
        }
