              "title": "Causes digestives",
              "blocks": [
                { "type": "list", "items": [
                  "<strong>Cancer colorectal</strong> — obstruction luminale, 1re cause à éliminer",
                  "Sténoses non tumorales : diverticulaire, inflammatoire, ischémique",
                  "Sténose anale : cancer du canal anal, inflammatoire, cicatricielle",
                  "Compression extrinsèque : tumeur ovarienne, carcinose, endométriose, adhérences"
                ]}
              ]
            },
            {
              "type": "card", "variant": "purple", "icon": "diagnostic", "icon_color": "purple",
              "title": "Causes extra-digestives",
              "blocks": [
                { "type": "phase", "kind": "mod", "text": "Neurologiques — 50 % des maladies neuro chroniques" },
                { "type": "list", "items": ["Parkinson, SEP, lésion médullaire, queue de cheval, AVC"] },
                { "type": "phase", "kind": "mod", "text": "Métaboliques" },
                { "type": "list", "items": [
                  "Hypothyroïdie, insuffisance surrénale, diabète",
                  "Hypercalcémie, hypokaliémie, hypomagnésémie"
                ]},
                { "type": "phase", "kind": "mod", "text": "Maladies de système" },
                { "type": "list", "items": ["Sclérodermie, amylose"] }
              ]
            }
          ]
        },
