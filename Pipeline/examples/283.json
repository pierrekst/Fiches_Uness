              { "color": "amber", "text": "Antipsychotiques" },
              { "color": "amber", "text": "Anticonvulsivants (carbamazépine)" },
              { "color": "amber", "text": "Antiparkinsoniens" },
              { "color": "amber", "text": "Fer oral" },
              { "color": "amber", "text": "Antidiarrhéiques / antispasmodiques" },
