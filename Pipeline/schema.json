{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Fiche UNESS",
  "type": "object",
  "required": ["header", "sections"],
  "additionalProperties": false,
  "properties": {
    "header": {
      "type": "object",
      "required": ["num", "title"],
      "additionalProperties": false,
      "properties": {
        "num": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" }, "maxItems": 5 }
      }
    },
    "objectifs": { "type": "string", "description": "Vision globale du chapitre, HTML inline autorisé." },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/section" }
    }
  },
  "$defs": {
    "icon": {
      "enum": ["definition", "epidemio", "physiopath", "mecanisme", "diagnostic",
               "traitement", "complications", "synthese", "info"]
    },
    "iconColor": { "enum": ["purple", "blue", "teal", "red", "amber", "coral"] },
    "alertColor": { "enum": ["red", "blue", "green", "amber", "teal"] },
    "pillColor": { "enum": ["red", "blue", "teal", "amber", "purple", "coral", "gray"] },
    "section": {
      "type": "object",
      "required": ["title", "icon", "blocks"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "icon": { "$ref": "#/$defs/icon" },
        "blocks": { "type": "array", "items": { "$ref": "#/$defs/block" } }
      }
    },
    "block": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "enum": ["card", "grid", "alert", "table", "kv", "steps", "pills", "list", "phase", "html"]
        },
        "variant": { "$ref": "#/$defs/iconColor" },
        "icon": { "$ref": "#/$defs/icon" },
        "icon_color": { "$ref": "#/$defs/iconColor" },
        "title": { "type": "string" },
        "cols": { "enum": [2, 3] },
        "color": { "$ref": "#/$defs/alertColor" },
        "kind": { "enum": ["prod", "mod", "sev"] },
        "text": { "type": "string" },
        "html": { "type": "string" },
        "headers": { "type": "array" },
        "rows": { "type": "array" },
        "items": { "type": "array" },
        "blocks": { "type": "array", "items": { "$ref": "#/$defs/block" } }
      }
    }
  }
}
